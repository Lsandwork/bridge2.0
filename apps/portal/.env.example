# Production: https://www.nuviobridge.com
NEXT_PUBLIC_SITE_URL=https://www.nuviobridge.com

# Tess AI provider (openai | anthropic | gemini) — switch without rebuild
AI_PROVIDER=gemini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
TESS_MODEL=gemini-2.5-flash
TESS_VOICE_MODEL=nova
TESS_VOICE_PROVIDER=openai
TESS_STT_MODEL=whisper-1

# YouTube search in My Space (Google Cloud Console → APIs → YouTube Data API v3 → Credentials)
# Local: set in apps/portal/.env.local then restart `npm run dev`
# Production: add YOUTUBE_API_KEY in Vercel project Environment Variables
YOUTUBE_API_KEY=

# Signs video play sessions so rewards work across Vercel serverless instances (any random string in production)
VIDEO_SESSION_SECRET=

# Tess local recommendations (Google Places — official API only)
GOOGLE_PLACES_API_KEY=
TESS_RECOMMENDATIONS_ENABLED=true
TESS_RECOMMENDATION_MAX_RESULTS=5
# Optional: YELP_API_KEY= (not required; Google Places is the primary source)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
